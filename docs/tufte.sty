% tufte.sty 
% Use:  \usepackage{tufte}    (in a standalone preamble)
%   or  \input{tufte.sty}     (in org-babel :headers blocks)
%
% Provides:
%   colours: ink, accentBlue, accentRed, accentPink, accentGreen, paper
%   styles:  ink, accent-pos/neg/alt, faint
%            (use-case)  uc, actor, sysbox, association, include
%            (onion)     ring
%            (UML class) umlbox, uml-uses, uml-manages, uml-compose
%   macro:   \umlclass{id}{x,y}{stereotype}{name}{attrs}{methods}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tufte}[2026/04/26 Tufte-esque TikZ palette and styles]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\usetikzlibrary{positioning,shapes.geometric,arrows.meta}

% ---- palette (matches tufte.mplstyle exactly) -------------------------------
\definecolor{ink}{HTML}{6B6B6B}
\definecolor{accentBlue}{HTML}{3B7BB8}
\definecolor{accentRed}{HTML}{C0392B}
\definecolor{accentPink}{HTML}{C76A98}
\definecolor{accentGreen}{HTML}{4A8B5C}
\definecolor{paper}{HTML}{FAF7F0}

% ---- global defaults --------------------------------------------------------
\tikzset{
  every picture/.style = {
    /utils/exec = \fontfamily{ppl}\selectfont,
    semithick, color = ink, text  = ink,
  },
  every node/.append style = {color = ink, text = ink, font = \rmfamily},
  ink/.style          = {draw=ink, line width=0.5pt},
  accent-pos/.style   = {draw=accentBlue, line width=0.9pt},
  accent-neg/.style   = {draw=accentRed,  line width=0.9pt},
  accent-alt/.style   = {draw=accentPink, line width=0.9pt},
  accent-alt2/.style  = {draw=accentGreen,line width=0.9pt},
  faint/.style        = {draw=ink!60, line width=0.4pt},
}

% ---- use-case diagrams ------------------------------------------------------
\tikzset{
  uc/.style = {
    draw=ink, line width=0.5pt, ellipse,
    minimum width=3.2cm, minimum height=0.9cm, align=center, inner sep=2pt,
  },
  actor/.style = {align=center, font=\rmfamily\itshape},
  sysbox/.style = {draw=ink, line width=0.5pt, rounded corners=4pt},
  association/.style = {draw=ink!70, line width=0.4pt, shorten >=2pt, shorten <=2pt},
  include/.style     = {-{Latex[length=2mm]}, dashed, draw=ink!70,
                        shorten >=2pt, shorten <=2pt},
  ring/.style 2 args = {fill=ink!#1, draw=ink!#2, line width=0.4pt},
}

% ---- UML class diagrams -----------------------------------------------------
\tikzset{
  umlbox/.style = {draw=ink, line width=0.5pt, rectangle, inner sep=0pt},
  uml-uses/.style    = {-{Latex[length=2mm]}, dashed, draw=ink!70, line width=0.4pt},
  uml-manages/.style = {-{Latex[length=2mm]}, draw=ink!70, line width=0.5pt},
  % Composition: filled diamond at the *whole* end of the line.
  %   \draw[uml-compose] (whole) -- (part);
  uml-compose/.style = {
    {Diamond[length=2.4mm,width=1.6mm,fill=ink]}-,
    draw=ink!80, line width=0.5pt,
  },
}

% \umlclass{<tikz-id>}{<x,y>}{<stereotype-or-empty>}{<class-name>}{<attrs>}{<methods>}
%   Use \\ to separate lines inside attrs / methods.
%   Width is fixed at 3.8cm; tweak the p{...} below if you need wider boxes.
\newcommand{\umlclass}[6]{%
  \node[umlbox] (#1) at (#2) {%
    \begin{tabular}{@{\hspace{4pt}}p{3.8cm}@{\hspace{4pt}}}
      \ifx\\#3\\\else\centering{\small$\langle\langle$\textit{#3}$\rangle\rangle$}\tabularnewline\fi
      \centering\textbf{#4}\tabularnewline[1pt]\hline
      \rule{0pt}{2.4ex}\footnotesize #5\tabularnewline[1pt]\hline
      \rule{0pt}{2.4ex}\footnotesize #6\tabularnewline[1pt]
    \end{tabular}%
  };%
}

\endinput